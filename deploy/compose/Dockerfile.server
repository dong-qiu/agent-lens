# Stage 1: build the Lens UI bundle (vite + React + TypeScript).
FROM node:22-alpine AS web-build
WORKDIR /web
COPY web/package.json web/package-lock.json* web/pnpm-lock.yaml* ./
RUN if [ -f pnpm-lock.yaml ]; then \
        npm install -g pnpm && pnpm install --frozen-lockfile; \
    elif [ -f package-lock.json ]; then \
        npm ci; \
    else \
        npm install; \
    fi
COPY web/ ./
RUN if [ -f pnpm-lock.yaml ]; then pnpm build; else npm run build; fi

# Stage 2: build the Go server with the UI embedded into internal/webui/dist.
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# Copy the built UI into the embed source path. Per internal/webui/embed.go,
# `//go:embed all:dist` reads from this dir at compile time. The .gitkeep
# checked into git is overwritten by the real bundle here.
COPY --from=web-build /web/dist/. ./internal/webui/dist/
RUN CGO_ENABLED=0 go build -o /out/agent-lens ./cmd/agent-lens

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/agent-lens /agent-lens
EXPOSE 8787
USER nonroot:nonroot
ENTRYPOINT ["/agent-lens"]
