FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/agent-lens ./cmd/agent-lens

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/agent-lens /agent-lens
EXPOSE 8787
USER nonroot:nonroot
ENTRYPOINT ["/agent-lens"]
