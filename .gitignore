# Build outputs
/bin/
/dist/
*.exe

# Go
*.test
*.out
coverage.txt
vendor/

# Frontend
web/node_modules/
web/dist/
web/.vite/
web/vite.config.js
web/vite.config.d.ts
*.tsbuildinfo

# Embedded UI bundle (populated by `make embed-webui` from web/dist; only
# .gitkeep is checked in so `go build` works before the first UI build).
internal/webui/dist/*
!internal/webui/dist/.gitkeep

# Env / local config
.env
.env.local
*.local
.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Compose state
deploy/compose/.data/

# Backups
/backups/

# Claude Code runtime (per-developer; never commit)
.claude/settings.local.json
.claude/worktrees/
